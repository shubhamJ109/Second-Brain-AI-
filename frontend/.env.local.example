# ─── Environment Configuration Template ──────────────────────────────────────
# Copy this to .env.local for local development.
# Do NOT commit your actual .env.local file to version control.

# The URL of your backend API (FastAPI)
# In production, this can be your backend domain (e.g. https://api.yourdomain.com)
# For local development, use the internal proxy:
INTERNAL_API_URL=http://localhost:8000/api
